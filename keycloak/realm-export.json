{
  "realm": "wardrobe",
  "enabled": true,
  "displayName": "Wardrobe",
  "loginTheme": "wardrobe",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "sslRequired": "external",
  "clients": [
    {
      "clientId": "wardrobe-frontend",
      "name": "Wardrobe Frontend",
      "description": "Angular SPA and future Capacitor Android client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "capacitor://localhost/*",
        "com.wardrobe.app:/callback"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "capacitor://localhost"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*##capacitor://localhost/*##com.wardrobe.app:/callback"
      },
      "protocolMappers": [
        {
          "name": "audience-wardrobe-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "wardrobe-api",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "demo",
      "email": "demo@wardrobe.local",
      "firstName": "Demo",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ]
    }
  ]
}
